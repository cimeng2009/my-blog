---
import Icon from "@components/common/Icon.astro";
import { url } from "@/utils/url-utils";

export interface BreadcrumbItem {
	label: string;
	href?: string; // 不填则视为当前页，无链接
	icon?: string; // 可选图标（iconify 名）
}

interface Props {
	items: BreadcrumbItem[];
	class?: string;
}

const { items, class: className = "" } = Astro.props;

// 移动端折叠用：取上一级（倒数第二个 item）
const parent = items.length >= 2 ? items[items.length - 2] : null;
---

<nav
	aria-label="Breadcrumb"
	class:list={[
		"breadcrumb-nav text-sm text-neutral-500 dark:text-neutral-400",
		className,
	]}
>
	<!-- 桌面/平板：完整路径 -->
	<ol class="breadcrumb-list hidden sm:flex items-center gap-1.5 flex-wrap">
		{
			items.map((it, i) => (
				<li class="flex items-center gap-1.5">
					{i > 0 && (
						<Icon
							name="material-symbols:chevron-right"
							class="text-xs text-neutral-300 dark:text-neutral-600"
						/>
					)}
					{it.href ? (
						<a
							href={it.href.startsWith("http") ? it.href : url(it.href)}
							class="flex items-center gap-1 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors"
						>
							{it.icon && <Icon name={it.icon} class="text-sm" />}
							<span>{it.label}</span>
						</a>
					) : (
						<span class="flex items-center gap-1 text-neutral-900 dark:text-neutral-100 font-medium">
							{it.icon && <Icon name={it.icon} class="text-sm" />}
							<span>{it.label}</span>
						</span>
					)}
				</li>
			))
		}
	</ol>

	<!-- 移动端：只保留"← 上一级"回退按钮 -->
	{
		parent && (
			<div class="sm:hidden">
				<a
					href={parent.href ? (parent.href.startsWith("http") ? parent.href : url(parent.href)) : "#"}
					class="inline-flex items-center gap-1 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors"
				>
					<Icon name="material-symbols:chevron-left" class="text-sm" />
					<span>{parent.label}</span>
				</a>
			</div>
		)
	}
</nav>
