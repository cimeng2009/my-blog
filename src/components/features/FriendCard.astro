---
export interface Props {
	title: string;
	href: string;
	imgurl: string;
	desc: string;
	tags?: string[];
}

const { title, href, imgurl, desc, tags = [] } = Astro.props;

// 类型标签颜色配置
const typeColors: Record<string, { bg: string; text: string }> = {
	Blog: { bg: "#3b82f6", text: "#ffffff" },
	Docs: { bg: "#f59e0b", text: "#ffffff" },
};

const primaryTag = tags[0] || "Blog";
const typeColor = typeColors[primaryTag] || typeColors.Blog;
---

<a
  class="friend-card-link"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  title={desc}
  data-desc={desc}
>
  <!-- 左上角类型标签 -->
  <span
    class="friend-card-type-badge"
    style={`background-color: ${typeColor.bg}; color: ${typeColor.text};`}
  >
    {primaryTag}
  </span>

  <!-- 左侧：头像 -->
  <div class="friend-card-left" data-title={title.slice(0, 4)}>
    <img
      src={imgurl}
      alt={title}
      class="friend-card-avatar"
      loading="lazy"
      onerror="this.style.opacity='0';this.parentElement?.classList.add('avatar-error');"
    />
  </div>

  <!-- 右侧内容：标题 + 描述 -->
  <div class="friend-card-right">
    <div class="friend-card-header">
      <h3 class="friend-card-title">{title}</h3>
      <svg
        class="friend-card-arrow"
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M7 17L17 7"></path>
        <path d="M7 7h10v10"></path>
      </svg>
    </div>
    <p class="friend-card-desc">{desc}</p>
  </div>

  <!-- 悬停时滑入的覆盖层 -->
  <div class="friend-card-overlay">
    <div class="friend-card-overlay-content">
      <h3 class="friend-card-overlay-title">{title}</h3>
      <p class="friend-card-overlay-desc">{desc}</p>
    </div>
  </div>
</a>

