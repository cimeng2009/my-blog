---
interface Tab {
	id: string;
	name: string;
	count?: number;
}

interface Props {
	tabs: Tab[];
	activeTab: string;
}

const { tabs, activeTab } = Astro.props;
---

<div class="border-b border-(--line-divider) mb-3 relative">
  <div class="overflow-x-auto" data-tab-scroll-container>
    <nav class="flex min-w-max space-x-8" aria-label="Tabs" data-tab-nav>
      <!-- 滑动下划线指示器 -->
      <div class="tab-underline-indicator" data-tab-indicator></div>
      
      {tabs.map((tab) => (
        <button
          class:list={[
            "tab-nav-btn whitespace-nowrap py-4 px-1 font-medium text-sm transition-colors duration-200",
            {
              "tab-nav-btn-active": tab.id === activeTab,
              "tab-nav-btn-inactive": tab.id !== activeTab
            }
          ]}
          data-tab={tab.id}
          type="button"
        >
          {tab.name}
          {tab.count !== undefined && (
            <span class="ml-2 tab-count">
              {tab.count}
            </span>
          )}
        </button>
      ))}
    </nav>
  </div>
</div>

<!-- 样式已迁移至 src/styles/pages/bangumi.css -->

<script is:inline>
  (function() {
    // 防止 swup 导航时重复注册 window 级监听器
    if (window.__tabNavInitialized) return;
    window.__tabNavInitialized = true;

    function initTabNavigation() {
      var tabButtons = document.querySelectorAll('[data-tab]');
      var sections = document.querySelectorAll('[data-section]');
      var indicator = document.querySelector('[data-tab-indicator]');

      function updateIndicator(targetBtn) {
        if (!indicator) return;
        var nav = targetBtn.closest('[data-tab-nav]');
        if (!nav) return;
        var navRect = nav.getBoundingClientRect();
        var btnRect = targetBtn.getBoundingClientRect();
        indicator.style.left = (btnRect.left - navRect.left) + 'px';
        indicator.style.width = btnRect.width + 'px';
        indicator.style.opacity = '1';
      }

      function hydrateVisibleImages(targetTab) {
        var visibleItems = document.querySelectorAll(
          '[data-section="' + targetTab + '"] [data-item-section="' + targetTab + '"]:not(.hidden)'
        );

        visibleItems.forEach(function(item) {
          if (item.style.display === 'none') return;
          var image = item.querySelector('img[data-src]');
          if (image) {
            var deferredSrc = image.getAttribute('data-src');
            if (deferredSrc) {
              image.setAttribute('src', deferredSrc);
              image.removeAttribute('data-src');
            }
          }
        });
      }

      function activateTab(targetTab, shouldSyncHash) {
        if (!targetTab) return;
        if (shouldSyncHash === undefined) shouldSyncHash = true;

        var targetButton = null;
        tabButtons.forEach(function(btn) {
          if (btn.dataset.tab === targetTab) targetButton = btn;
        });
        if (!targetButton) return;

        tabButtons.forEach(function(btn) {
          btn.classList.remove('tab-nav-btn-active');
          btn.classList.add('tab-nav-btn-inactive');
        });
        targetButton.classList.remove('tab-nav-btn-inactive');
        targetButton.classList.add('tab-nav-btn-active');

        updateIndicator(targetButton);

        sections.forEach(function(section) {
          if (section.dataset.section === targetTab) {
            section.classList.remove('hidden');
          } else {
            section.classList.add('hidden');
          }
        });

        window.dispatchEvent(new CustomEvent('tabSwitched', { detail: { sectionId: targetTab } }));
        hydrateVisibleImages(targetTab);

        if (shouldSyncHash) {
          var nextHash = '#' + encodeURIComponent(targetTab);
          if (window.location.hash !== nextHash) {
            window.history.replaceState(null, '', nextHash);
          }
        }
      }

      function getTabFromHash() {
        var hash = window.location.hash.replace(/^#/, '');
        if (!hash) return '';
        try { return decodeURIComponent(hash); } catch(e) { return ''; }
      }

      // 绑定点击事件（新 DOM 元素，不会重复）
      tabButtons.forEach(function(button) {
        button.addEventListener('click', function(event) {
          var targetTab = event.currentTarget.dataset.tab;
          if (targetTab) activateTab(targetTab, true);
        });
      });

      var initialTab = getTabFromHash();
      if (initialTab) {
        activateTab(initialTab, false);
      } else {
        var activeBtn = document.querySelector('.tab-nav-btn-active');
        if (activeBtn) {
          requestAnimationFrame(function() { updateIndicator(activeBtn); });
        }
      }
    }

    // hashchange 只注册一次
    window.addEventListener('hashchange', function() {
      var hash = window.location.hash.replace(/^#/, '');
      if (!hash) return;
      try { hash = decodeURIComponent(hash); } catch(e) { return; }
      var tabButtons = document.querySelectorAll('[data-tab]');
      var sections = document.querySelectorAll('[data-section]');
      var targetButton = null;
      tabButtons.forEach(function(btn) { if (btn.dataset.tab === hash) targetButton = btn; });
      if (!targetButton) return;
      tabButtons.forEach(function(btn) {
        btn.classList.remove('tab-nav-btn-active');
        btn.classList.add('tab-nav-btn-inactive');
      });
      targetButton.classList.remove('tab-nav-btn-inactive');
      targetButton.classList.add('tab-nav-btn-active');
      sections.forEach(function(section) {
        if (section.dataset.section === hash) section.classList.remove('hidden');
        else section.classList.add('hidden');
      });
    });

    // resize 只注册一次
    window.addEventListener('resize', function() {
      var indicator = document.querySelector('[data-tab-indicator]');
      var activeBtn = document.querySelector('.tab-nav-btn-active');
      if (indicator && activeBtn) {
        var nav = activeBtn.closest('[data-tab-nav]');
        if (nav) {
          var navRect = nav.getBoundingClientRect();
          var btnRect = activeBtn.getBoundingClientRect();
          indicator.style.left = (btnRect.left - navRect.left) + 'px';
          indicator.style.width = btnRect.width + 'px';
        }
      }
    });

    // 初始化
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTabNavigation);
    } else {
      initTabNavigation();
    }
    document.addEventListener('astro:page-load', initTabNavigation);
  })();
</script>
