---
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import { url } from "@/utils/url-utils";

interface Props {
	id: string;
	name: string;
	cover: string;
	description?: string;
	date?: string;
	location?: string;
	tags?: string[];
	photoCount: number;
}

const { id, name, cover, description, date, location, tags, photoCount } =
	Astro.props;

function truncateLocation(loc: string | undefined, maxChars: number = 4): string {
	if (!loc) return "";
	if (loc.length <= maxChars) return loc;
	return loc.slice(0, maxChars) + "...";
}

const displayLocation = truncateLocation(location);
---

<a
  href={url(`/gallery/${id}/`)}
  data-tags={tags?.join(",") || ""}
  class="album-card group"
>
  <!-- Image wrapper -->
  <div class="album-card-imgbox">
    {cover ? (
      <img
        src={cover}
        alt={name}
        class="album-card-img"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="w-full h-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center">
        <div class="text-gray-400 text-5xl">&#x1f4f7;</div>
      </div>
    )}

    <!-- Photo count badge (常驻，悬停时消失) -->
    <div class="album-card-badge">
      {photoCount} {i18n(I18nKey.galleryPhotos)}
    </div>

    <!-- Tags overlay (图片内左下角，悬停时消失，最多4个) -->
    {tags && tags.length > 0 && (
      <div class="album-card-tags-overlay">
        {tags.slice(0, 4).map((tag) => (
          <span class="album-card-tag-overlay">{tag}</span>
        ))}
      </div>
    )}
  </div>

  <!-- Details (悬停时露出) -->
  <div class="album-card-details">
    <h3 class="album-card-title">{name}</h3>

    <div class="album-card-meta">
      {date && <span>{date}</span>}
      {displayLocation && (
        <span class="album-card-location">
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z"/></svg>
          {displayLocation}
        </span>
      )}
    </div>


  </div>
</a>

<style>
  .album-card {
    position: relative;
    display: block;
    overflow: visible;
    width: 100%;
    height: 254px;
    background: #1f1f1f;
    border-radius: 4px;
    box-shadow: 0 2px 10px rgba(0, 0, 0, .2);
    transition: 0.3s;
    text-decoration: none;
  }

  :global(.dark) .album-card {
    background: #f5f5f5;
    box-shadow: 0 2px 10px rgba(0, 0, 0, .4);
  }

  /* 伪元素层叠效果 */
  .album-card::before,
  .album-card::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 4px;
    background: #1f1f1f;
    transition: 0.5s;
    z-index: -1;
  }

  :global(.dark) .album-card::before,
  :global(.dark) .album-card::after {
    background: #f5f5f5;
  }

  .album-card:hover::before {
    transform: rotate(20deg);
  }

  .album-card:hover::after {
    transform: rotate(10deg);
    box-shadow: 0 2px 20px rgba(0, 0, 0, .2);
  }

  :global(.dark) .album-card:hover::after {
    box-shadow: 0 2px 20px rgba(0, 0, 0, .4);
  }

  /* Image box */
  .album-card-imgbox {
    position: absolute;
    top: 10px;
    left: 10px;
    bottom: 10px;
    right: 10px;
    background: #222;
    transition: bottom 0.5s;
    z-index: 1;
    overflow: hidden;
  }

  .album-card:hover .album-card-imgbox {
    bottom: 80px;
  }

  .album-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
    transition: transform 0.5s;
  }

  .album-card:hover .album-card-img {
    transform: scale(1.05);
  }

  /* Badge */
  .album-card-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    padding: 4px 10px;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    color: #fff;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    z-index: 2;
    transition: opacity 0.3s;
  }

  .album-card:hover .album-card-badge {
    opacity: 0;
  }

  /* Tags overlay inside image */
  .album-card-tags-overlay {
    position: absolute;
    bottom: 8px;
    left: 8px;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    z-index: 2;
    transition: opacity 0.3s;
  }

  .album-card:hover .album-card-tags-overlay {
    opacity: 0;
  }

  .album-card-tag-overlay {
    font-size: 0.65rem;
    padding: 2px 8px;
    border-radius: 4px;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    color: #fff;
    white-space: nowrap;
  }

  /* Details */
  .album-card-details {
    position: absolute;
    left: -10px;
    right: 0;
    bottom: 5px;
    height: 60px;
    text-align: center;
    text-transform: uppercase;
    z-index: 0;
  }

  .album-card-title {
    font-weight: 600;
    font-size: 1.25rem;
    color: #fff;
    line-height: 1.2;
    margin: 0;
  }

  :global(.dark) .album-card-title {
    color: #444;
  }

  .album-card-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: #ccc;
    margin-top: 4px;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    padding: 0 10px;
  }

  :global(.dark) .album-card-meta {
    color: #555;
  }

  .album-card-meta > span {
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .album-card-location {
    display: inline-flex;
    align-items: center;
    gap: 0.125rem;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    max-width: 100%;
  }


</style>
