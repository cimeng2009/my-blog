---
import { getCollection } from "astro:content";
// 笔记管理页面 - 往已有笔记本里写笔记，通过 GitHub Gist 存储
import { externalNotebooksConfig } from "@/config/externalNotebooksConfig";

// 读取本地笔记本列表
const allEntries = await getCollection("notebooks");
const notebookFolders = new Set<string>();
for (const entry of allEntries) {
	const normalizedId = entry.id.replace(/\\/g, "/");
	const match = normalizedId.match(/^([^/]+)\//);
	if (match && match[1] !== "readme") {
		notebookFolders.add(match[1]);
	}
}
const notebookList = [...notebookFolders].sort();
---

<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>笔记管理</title>
  <style is:inline>
    :root {
      --primary: oklch(0.25 0 0);
      --primary-hover: oklch(0.15 0 0);
      --primary-light: oklch(0.25 0 0 / 0.08);
      --primary-light-hover: oklch(0.25 0 0 / 0.12);

      --bg: oklch(1 0 0);
      --bg-body: oklch(0.975 0.002 260);
      --bg-hover: oklch(0.96 0.002 260);
      --bg-active: oklch(0.94 0.002 260);
      --bg-secondary: oklch(0.97 0.002 260);
      --bg-tertiary: oklch(0.94 0.002 260);

      --text: oklch(0.12 0.005 260);
      --text-secondary: oklch(0.45 0.01 260);
      --text-tertiary: oklch(0.62 0.01 260);
      --text-muted: oklch(0.75 0.01 260);

      --border: oklch(0.88 0.005 260);
      --border-light: oklch(0.93 0.003 260);

      --hover: oklch(0.96 0.002 260);
      --active: oklch(0.94 0.002 260);

      --input-bg: oklch(1 0 0);
      --input-border: oklch(0.88 0.005 260);

      --success: oklch(0.58 0.12 148);
      --success-bg: oklch(0.58 0.12 148 / 0.1);
      --warning: oklch(0.70 0.14 78);
      --warning-bg: oklch(0.70 0.14 78 / 0.1);
      --danger: oklch(0.58 0.20 25);
      --danger-bg: oklch(0.58 0.20 25 / 0.1);
      --info: oklch(0.60 0.15 250);
      --info-bg: oklch(0.60 0.15 250 / 0.1);

      --radius-sm: 4px;
      --radius: 6px;
      --radius-lg: 10px;
      --radius-xl: 14px;

      --shadow-sm: 0 1px 2px oklch(0 0 0 / 0.04);
      --shadow: 0 1px 3px oklch(0 0 0 / 0.06), 0 1px 2px oklch(0 0 0 / 0.04);
      --shadow-md: 0 4px 6px -1px oklch(0 0 0 / 0.06), 0 2px 4px -2px oklch(0 0 0 / 0.06);
      --shadow-lg: 0 10px 15px -3px oklch(0 0 0 / 0.06), 0 4px 6px -4px oklch(0 0 0 / 0.06);

      --transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      --code-bg: oklch(0.97 0.002 260);
    }
    :root.dark {
      --primary: oklch(0.90 0 0);
      --primary-hover: oklch(1 0 0);
      --primary-light: oklch(0.90 0 0 / 0.1);
      --primary-light-hover: oklch(0.90 0 0 / 0.16);

      --bg: oklch(0.14 0.005 260);
      --bg-body: oklch(0.11 0.005 260);
      --bg-hover: oklch(0.18 0.005 260);
      --bg-active: oklch(0.22 0.005 260);
      --bg-secondary: oklch(0.16 0.005 260);
      --bg-tertiary: oklch(0.20 0.005 260);

      --text: oklch(0.90 0.01 260);
      --text-secondary: oklch(0.65 0.01 260);
      --text-tertiary: oklch(0.50 0.01 260);
      --text-muted: oklch(0.38 0.01 260);

      --border: oklch(0.28 0.005 260);
      --border-light: oklch(0.22 0.005 260);

      --hover: oklch(0.18 0.005 260);
      --active: oklch(0.22 0.005 260);

      --input-bg: oklch(0.14 0.005 260);
      --input-border: oklch(0.28 0.005 260);

      --shadow-sm: 0 1px 2px oklch(0 0 0 / 0.3);
      --shadow: 0 1px 3px oklch(0 0 0 / 0.4), 0 1px 2px oklch(0 0 0 / 0.3);
      --shadow-md: 0 4px 6px -1px oklch(0 0 0 / 0.4), 0 2px 4px -2px oklch(0 0 0 / 0.3);
      --shadow-lg: 0 10px 15px -3px oklch(0 0 0 / 0.4), 0 4px 6px -4px oklch(0 0 0 / 0.3);
      --code-bg: oklch(0.18 0.005 260);
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Noto Sans SC", "Helvetica Neue", Arial, sans-serif;
      background: var(--bg-body); color: var(--text); min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      line-height: 1.6;
      font-size: 14px;
    }

    a { color: inherit; text-decoration: none; }
    button { font-family: inherit; cursor: pointer; border: none; background: none; }
    input { font-family: inherit; }
    select { font-family: inherit; }

    /* ===== Scrollbar ===== */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--text-tertiary); }

    .navbar {
      position: sticky; top: 0; z-index: 50;
      background: var(--bg); border-bottom: 1px solid var(--border-light);
    }
    .navbar-inner {
      max-width: 960px; margin: 0 auto; padding: 0 1rem;
      display: flex; align-items: center; justify-content: space-between; height: 60px;
    }
    .navbar-left { display: flex; align-items: center; gap: 0.75rem; }
    .navbar-left .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--primary); }
    .navbar-left h1 { font-size: 16px; font-weight: 600; color: var(--text); letter-spacing: -0.01em; }
    .nav-right { display: flex; align-items: center; gap: 0.5rem; }
    .back-link {
      display: inline-flex; align-items: center; gap: 0.375rem;
      color: var(--text-secondary); text-decoration: none; font-size: 13px;
      padding: 0.375rem 0.625rem; border-radius: var(--radius); transition: var(--transition);
    }
    .back-link:hover { color: var(--text); background: var(--bg-hover); }
    .back-link svg { width: 16px; height: 16px; }
    .logout-btn {
      background: transparent; border: 1px solid var(--border); color: var(--text-secondary);
      padding: 0.375rem 0.75rem; font-size: 13px; border-radius: var(--radius);
      cursor: pointer; transition: var(--transition); font-family: inherit;
      height: 32px; display: inline-flex; align-items: center;
    }
    .logout-btn:hover { border-color: var(--danger); color: var(--danger); background: var(--danger-bg); }

    .container { max-width: 960px; margin: 0 auto; padding: 24px 1rem 4rem; }

    .card {
      background: var(--bg); border: 1px solid var(--border-light); border-radius: var(--radius-lg);
      padding: 20px; margin-bottom: 16px;
      transition: var(--transition);
    }
    .card:hover {
      border-color: var(--border);
      box-shadow: var(--shadow-md);
      transform: translateY(-1px);
    }

    .status-bar {
      display: flex; align-items: center; gap: 0.5rem;
      padding: 0.75rem 1rem; margin-bottom: 16px;
      border: 1px solid var(--border-light); border-radius: var(--radius-lg); font-size: 13px; color: var(--text-secondary);
      background: var(--bg);
      transition: var(--transition);
    }
    .status-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .status-dot.ok { background: var(--success); }
    .status-dot.err { background: var(--danger); }

    .field { margin-bottom: 16px; }
    .field:last-child { margin-bottom: 0; }
    .field-label {
      display: flex; align-items: center; gap: 0.375rem;
      font-size: 13px; font-weight: 500; color: var(--text-secondary);
      margin-bottom: 8px;
    }
    .field-label .icon { font-size: 14px; }

    .input-single {
      width: 100%; padding: 0.5rem 0.75rem; border: 1px solid var(--border);
      border-radius: var(--radius); font-size: 14px; background: var(--input-bg);
      color: var(--text); outline: none; transition: var(--transition); height: 38px;
      font-family: inherit;
    }
    .input-single:focus { border-color: var(--primary); box-shadow: 0 0 0 3px var(--primary-light); }
    .input-single::placeholder { color: var(--text-muted); }

    select {
      width: 100%; padding: 0.5rem 0.75rem; border: 1px solid var(--border);
      border-radius: var(--radius); font-size: 14px; background: var(--input-bg);
      color: var(--text); outline: none; transition: var(--transition); height: 38px;
      cursor: pointer; font-family: inherit; appearance: auto;
    }
    select:focus { border-color: var(--primary); box-shadow: 0 0 0 3px var(--primary-light); }

    input[type="date"] {
      width: 100%; padding: 0.5rem 0.75rem; border: 1px solid var(--border);
      border-radius: var(--radius); font-size: 14px; background: var(--input-bg);
      color: var(--text); outline: none; transition: var(--transition); height: 38px;
      font-family: inherit;
    }
    input[type="date"]:focus { border-color: var(--primary); box-shadow: 0 0 0 3px var(--primary-light); }

    textarea {
      width: 100%; min-height: 60px; padding: 0.625rem 0.75rem;
      border: 1px solid var(--border); border-radius: var(--radius);
      font-size: 14px; line-height: 1.7; background: var(--input-bg);
      color: var(--text); outline: none; resize: vertical;
      font-family: inherit; transition: var(--transition);
    }
    textarea:focus { border-color: var(--primary); box-shadow: 0 0 0 3px var(--primary-light); }
    textarea::placeholder { color: var(--text-muted); }

    /* ===== 编辑器 ===== */
    .editor-container {
      display: grid; grid-template-columns: 1fr; gap: 0;
      border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden;
    }
    @media (min-width: 768px) {
      .editor-container { grid-template-columns: 1fr 1fr; }
    }
    .editor-pane { display: flex; flex-direction: column; }
    .editor-pane-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.75rem 1rem;
      border-bottom: 1px solid var(--border-light);
      font-size: 13px; font-weight: 500; color: var(--text-tertiary);
      background: var(--bg-secondary);
    }
    .editor-textarea {
      width: 100%; min-height: 350px; padding: 1rem;
      border: none; border-radius: 0;
      font-size: 14px; line-height: 1.8; background: var(--input-bg);
      color: var(--text); outline: none; resize: vertical;
      font-family: 'JetBrains Mono', 'Fira Code', monospace;
    }
    .editor-textarea::placeholder { color: var(--text-muted); }
    .preview-pane {
      border-top: 1px solid var(--border-light);
      min-height: 350px; padding: 1rem;
      overflow-y: auto; font-size: 14px; line-height: 1.8;
      background: var(--bg);
    }
    @media (min-width: 768px) {
      .preview-pane { border-top: none; border-left: 1px solid var(--border-light); }
    }
    .preview-pane h1, .preview-pane h2, .preview-pane h3 { margin: 1em 0 0.5em; color: var(--text); font-weight: 600; }
    .preview-pane h1 { font-size: 1.5rem; }
    .preview-pane h2 { font-size: 1.25rem; }
    .preview-pane h3 { font-size: 1.1rem; }
    .preview-pane p { margin: 0 0 0.75em; }
    .preview-pane ul, .preview-pane ol { margin: 0 0 0.75em; padding-left: 1.5em; }
    .preview-pane li { margin-bottom: 0.25em; }
    .preview-pane blockquote { border-left: 3px solid var(--primary); padding-left: 1em; margin: 0 0 0.75em; color: var(--text-secondary); background: var(--bg-secondary); padding: 0.75em 1em; border-radius: 0 var(--radius) var(--radius) 0; }
    .preview-pane code { font-family: 'JetBrains Mono', monospace; background: var(--code-bg); padding: 0.15em 0.4em; font-size: 0.85em; border-radius: var(--radius-sm); }
    .preview-pane pre { background: var(--code-bg); padding: 1em; margin: 0 0 0.75em; overflow-x: auto; border-radius: var(--radius); }
    .preview-pane pre code { background: none; padding: 0; border-radius: 0; }
    .preview-pane img { max-width: 100%; border-radius: var(--radius); }
    .preview-pane a { color: var(--primary); text-decoration: underline; text-underline-offset: 2px; }
    .preview-pane hr { border: none; border-top: 1px solid var(--border-light); margin: 1.5em 0; }

    .editor-toolbar { display: flex; gap: 0.25rem; flex-wrap: wrap; }
    .toolbar-btn {
      width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;
      border: 1px solid var(--border); border-radius: var(--radius); background: var(--bg); color: var(--text-secondary);
      cursor: pointer; font-size: 13px; transition: var(--transition); font-family: inherit;
    }
    .toolbar-btn:hover { border-color: var(--text-tertiary); color: var(--text); background: var(--bg-hover); }

    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
      padding: 0.5rem 1rem; border: 1px solid var(--border); border-radius: var(--radius);
      font-size: 14px; font-weight: 500; cursor: pointer; height: 38px;
      transition: var(--transition); font-family: inherit; background: transparent; color: var(--text);
      white-space: nowrap; user-select: none;
    }
    .btn:hover { border-color: var(--text-tertiary); color: var(--text); background: var(--bg-hover); }
    .btn:active { background: var(--bg-active); transform: translateY(0); }
    .btn-primary { background: var(--primary); color: var(--bg); width: 100%; border-color: var(--primary); }
    .btn-primary:hover {
      background: var(--primary-hover);
      box-shadow: var(--shadow-md);
      transform: translateY(-1px);
      color: var(--bg);
      border-color: var(--primary-hover);
    }
    .btn-primary:active {
      transform: translateY(0);
      box-shadow: var(--shadow-sm);
    }
    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }
    .btn-sm {
      padding: 0.375rem 0.75rem; font-size: 13px; height: 32px;
      background: transparent; color: var(--text-secondary); border: 1px solid var(--border);
    }
    .btn-sm:hover { border-color: var(--text-tertiary); color: var(--text); background: var(--bg-hover); }
    .btn-danger-sm {
      padding: 0.375rem 0.75rem; font-size: 13px; height: 32px;
      background: transparent; color: var(--text-tertiary); border: 1px solid var(--border);
    }
    .btn-danger-sm:hover { border-color: var(--danger); color: var(--danger); background: var(--danger-bg); }

    /* ===== 笔记列表 ===== */
    .list-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 0.75rem;
    }
    .list-header .count { font-size: 13px; color: var(--text-tertiary); }

    .entry-row {
      display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;
      padding: 1rem 0; border-bottom: 1px solid var(--border-light);
      transition: var(--transition);
    }
    .entry-row:hover { background: var(--bg-hover); margin: 0 -12px; padding-left: 12px; padding-right: 12px; border-radius: var(--radius); }
    .entry-row:last-child { border-bottom: none; }
    .entry-info { flex: 1; min-width: 0; }
    .entry-title { font-size: 14px; font-weight: 500; color: var(--text); }
    .entry-meta { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.375rem; font-size: 12px; color: var(--text-tertiary); }
    .entry-meta .sep { opacity: 0.4; }
    .entry-preview {
      font-size: 12px; color: var(--text-tertiary); margin-top: 0.375rem;
      display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;
    }
    .entry-actions { display: flex; gap: 0.5rem; flex-shrink: 0; }

    .empty-state { text-align: center; padding: 3rem 1rem; color: var(--text-tertiary); }
    .empty-state .icon { font-size: 2rem; margin-bottom: 0.75rem; opacity: 0.4; }
    .empty-state p { font-size: 14px; }

    .toast {
      position: fixed; top: 80px; left: 50%; transform: translateX(-50%) translateY(-8px);
      padding: 0.75rem 1.25rem; font-size: 14px; border-radius: var(--radius);
      font-weight: 500; z-index: 999; opacity: 0;
      transition: var(--transition);
      pointer-events: none; border: 1px solid var(--border-light);
      box-shadow: var(--shadow-lg);
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
    .toast.ok { background: var(--success); color: #fff; border-color: var(--success); }
    .toast.err { background: var(--danger); color: #fff; border-color: var(--danger); }

    .dark-fab {
      position: fixed; bottom: 1.5rem; right: 1.5rem;
      width: 44px; height: 44px; border-radius: 50%;
      background: var(--bg); border: 1px solid var(--border-light);
      cursor: pointer; font-size: 1.25rem;
      display: flex; align-items: center; justify-content: center;
      transition: var(--transition);
      box-shadow: var(--shadow-md);
      z-index: 40;
    }
    .dark-fab:hover { border-color: var(--border); background: var(--bg-hover); transform: translateY(-2px); box-shadow: var(--shadow-lg); }

    .spinner {
      display: inline-block; width: 16px; height: 16px;
      border: 2px solid var(--border); border-top-color: var(--primary);
      border-radius: 50%; animation: spin 0.6s linear infinite;
      vertical-align: middle; margin-right: 0.5rem;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .hidden { display: none !important; }
    .edit-bar { display: flex; gap: 0.5rem; margin-top: 0.75rem; }

    .notebook-tabs {
      display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem;
    }
    .notebook-tab {
      padding: 0.375rem 1rem; border: 1px solid var(--border); border-radius: var(--radius);
      font-size: 13px; cursor: pointer; transition: var(--transition); height: 32px;
      background: transparent; color: var(--text-secondary); font-family: inherit;
      display: inline-flex; align-items: center;
    }
    .notebook-tab:hover { border-color: var(--text-tertiary); color: var(--text); background: var(--bg-hover); }
    .notebook-tab.active { background: var(--primary); color: var(--bg); border-color: var(--primary); }

    @media (min-width: 768px) {
      .container { padding: 32px 1.5rem 4rem; }
      .card { padding: 24px; }
    }
    @media (max-width: 480px) {
      .navbar-inner { padding: 0 1rem; }
      .container { padding: 16px 1rem 3rem; }
      .card { padding: 16px; }
      .editor-textarea { min-height: 250px; }
      .preview-pane { min-height: 200px; }
    }
  </style>
</head>
<body>

  <div id="admin-main">
    <nav class="navbar">
      <div class="navbar-inner">
        <div class="navbar-left">
          <span class="dot"></span>
          <h1>笔记管理</h1>
        </div>
        <div class="nav-right">
          <a href="/admin/" class="back-link" data-no-swup>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><polyline points="12 19 5 12 12 5"/></svg>
            <span>后台</span>
          </a>
          <button class="logout-btn" onclick="doLogout()">退出</button>
        </div>
      </div>
    </nav>

    <div class="container">
      <!-- 连接状态 -->
      <div class="status-bar" id="status-bar">
        <span class="status-dot" id="status-dot"></span>
        <span id="status-text">正在连接...</span>
      </div>

      <!-- Token 输入 -->
      <div class="card" id="token-card">
        <div class="field">
          <div class="field-label"><span class="icon">🔑</span> GitHub Token</div>
          <div style="display:flex;gap:0.5rem;">
            <input type="text" id="token-input" placeholder="ghp_xxx 或 github_pat_xxx" autocomplete="off" class="input-single" style="flex:1;" />
            <button class="btn btn-sm" onclick="applyToken()">连接</button>
            <button class="btn btn-sm" id="disconnect-btn" onclick="disconnectToken()" style="display:none;">断开</button>
          </div>
          <div style="margin-top:0.5rem;font-size:0.75rem;color:var(--text-tertiary);">
            与说说后台共用同一个 Token，需要 <a href="https://github.com/settings/tokens/new?scopes=gist&description=notebooks-writer" target="_blank" style="color:var(--primary);">gist 权限</a>
          </div>
        </div>
      </div>

      <!-- 选择笔记本 -->
      <div class="card">
        <div class="field-label"><span class="icon">📓</span> 选择笔记本</div>
        <div class="notebook-tabs" id="notebook-tabs">
          {notebookList.map((name) => {
            const hasGist = externalNotebooksConfig.notebookGists?.[name];
            return (
              <button class="notebook-tab" data-notebook={name}>
                {hasGist ? "✅ " : "⚠️ "}{name}
              </button>
            );
          })}
        </div>
        <div style="margin-top:0.5rem;font-size:0.75rem;color:var(--text-tertiary);">
          ⚠️ = 未配置 Gist（首次保存自动创建，需手动填回配置） ✅ = 已配置
        </div>
      </div>

      <!-- 写笔记 -->
      <div class="card" id="editor-card">
        <div class="field-label"><span class="icon">✍️</span> 写笔记 → <strong id="target-notebook" style="margin-left:0.25rem;">未选择</strong></div>
        <div class="field">
          <div class="field-label">快速模板</div>
          <div id="template-buttons" style="display:flex;gap:0.375rem;flex-wrap:wrap;"></div>
        </div>
        <div class="field">
          <div class="field-label">标题</div>
          <input type="text" class="input-single" id="entry-title" placeholder="笔记标题（可选）" />
        </div>
        <div class="field">
          <div class="field-label">日期</div>
          <input type="date" id="entry-date" />
        </div>
        <div class="field">
          <div class="field-label">内容（Markdown）</div>
          <div class="editor-container">
            <div class="editor-pane">
              <div class="editor-pane-header">
                <span>编辑</span>
                <div class="editor-toolbar">
                  <button class="toolbar-btn" onclick="insertMd('**','**')" title="加粗">B</button>
                  <button class="toolbar-btn" onclick="insertMd('*','*')" title="斜体">I</button>
                  <button class="toolbar-btn" onclick="insertMd('`','`')" title="行内代码">&lt;&gt;</button>
                  <button class="toolbar-btn" onclick="insertMd('\n```\n','\n```\n')" title="代码块">{}</button>
                  <button class="toolbar-btn" onclick="insertMd('[','](url)')" title="链接">🔗</button>
                  <button class="toolbar-btn" onclick="insertMd('![','](url)')" title="图片">🖼</button>
                  <button class="toolbar-btn" onclick="insertMd('> ','')" title="引用">❝</button>
                  <button class="toolbar-btn" onclick="insertMd('- ','')" title="列表">☰</button>
                </div>
              </div>
              <textarea class="editor-textarea" id="content-input" placeholder="用 Markdown 写下你的笔记..."></textarea>
            </div>
            <div class="editor-pane">
              <div class="editor-pane-header"><span>预览</span></div>
              <div class="preview-pane" id="preview-pane">
                <div class="empty-state" style="padding:2rem;"><p>开始编辑后预览内容</p></div>
              </div>
            </div>
          </div>
        </div>
        <button class="btn btn-primary" id="submit-btn" onclick="submitEntry()">保存笔记</button>
        <div class="hidden" id="edit-bar" style="display:flex;gap:0.5rem;margin-top:0.5rem;">
          <button class="btn btn-sm" onclick="cancelEdit()" style="flex:1;">取消编辑</button>
        </div>
      </div>

      <!-- 已有笔记 -->
      <div class="card">
        <div class="list-header">
          <div class="field-label" style="margin:0"><span class="icon">📋</span> <span id="list-title">已有笔记</span></div>
          <span class="count" id="list-count"></span>
        </div>
        <div id="entries-list">
          <div class="empty-state"><p>请先选择笔记本</p></div>
        </div>
      </div>
    </div>
  </div>

  <button class="dark-fab" onclick="toggleDark()" title="切换暗色模式">🌙</button>
  <div class="toast" id="toast"></div>

  <script is:inline
    data-token={externalNotebooksConfig.githubToken || ""}
    data-gists={JSON.stringify(externalNotebooksConfig.notebookGists || {})}
    data-templates={JSON.stringify(externalNotebooksConfig.templates || [])}>
    var _script = document.currentScript;
    var ENV_TOKEN = _script.getAttribute("data-token") || "";
    var TOKEN = localStorage.getItem("gh_moments_token") || ENV_TOKEN || "";
    var NOTEBOOK_GISTS = JSON.parse(_script.getAttribute("data-gists") || "{}");
    var TEMPLATES = JSON.parse(_script.getAttribute("data-templates") || "[]");
    var FILE_NAME = "notebooks-entries.json";
    var API = "https://api.github.com";

    var currentNotebook = "";
    var editingEntryId = null;
    var allEntries = [];

    function $(id) { return document.getElementById(id); }
    function esc(t) { var d = document.createElement("div"); d.textContent = t; return d.innerHTML; }
    function toast(msg, type) {
      var el = $("toast"); el.textContent = msg; el.className = "toast " + type + " show";
      clearTimeout(el._t); el._t = setTimeout(function() { el.className = "toast"; }, 2800);
    }
    function toggleDark() {
      document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", document.documentElement.classList.contains("dark") ? "dark" : "light");
    }
    if (localStorage.getItem("theme") === "dark") document.documentElement.classList.add("dark");
    function doLogout() { sessionStorage.removeItem("admin_auth"); window.location.href = "/admin/"; }
    function setStatus(ok, text) {
      $("status-dot").className = "status-dot " + (ok ? "ok" : "err");
      $("status-text").textContent = text;
    }

    // ===== 笔记本标签切换 =====
    var tabs = document.querySelectorAll(".notebook-tab");
    tabs.forEach(function(tab) {
      tab.addEventListener("click", function() {
        tabs.forEach(function(t) { t.classList.remove("active"); });
        tab.classList.add("active");
        currentNotebook = tab.getAttribute("data-notebook");
        $("target-notebook").textContent = currentNotebook;
        $("list-title").textContent = currentNotebook + " 的笔记";
        loadEntries();
      });
    });

    // ===== Token =====
    function applyToken() {
      var t = $("token-input").value.trim();
      if (!t) { toast("请输入 Token", "err"); return; }
      TOKEN = t;
      localStorage.setItem("gh_moments_token", t);
      validateAndLoad();
    }
    function disconnectToken() {
      TOKEN = "";
      localStorage.removeItem("gh_moments_token");
      $("token-input").value = "";
      $("disconnect-btn").style.display = "none";
      setStatus(false, "已断开");
    }
    function validateAndLoad() {
      if (!TOKEN) { setStatus(false, "请输入 Token"); return; }
      setStatus(false, "正在连接...");
      $("disconnect-btn").style.display = "none";
      fetch(API + "/user", { headers: { "Authorization": "Bearer " + TOKEN } })
        .then(function(r) {
          if (r.ok) { setStatus(true, "已连接"); $("disconnect-btn").style.display = ""; initGist(); }
          else if (r.status === 401) { setStatus(false, "Token 无效"); }
          else { setStatus(false, "连接失败 HTTP " + r.status); }
        })
        .catch(function(e) { setStatus(false, "网络错误: " + e.message); });
    }

    // ===== 初始化 =====
    function initGist() {
      var configured = Object.keys(NOTEBOOK_GISTS).filter(function(k) { return NOTEBOOK_GISTS[k]; });
      setStatus(true, "已连接（" + configured.length + " 个笔记本已配置 Gist）");
    }

    // ===== 加载当前笔记本的笔记 =====
    function loadEntries() {
      if (!currentNotebook) return;
      var gistId = NOTEBOOK_GISTS[currentNotebook];
      if (!gistId) {
        $("entries-list").innerHTML = '<div class="empty-state"><div class="icon">⚠️</div><p>该笔记本未配置 Gist<br><span style="font-size:0.75rem;">首次保存时自动创建</span></p></div>';
        $("list-count").textContent = "";
        return;
      }

      $("entries-list").innerHTML = '<div class="empty-state"><span class="spinner"></span></div>';
      fetch(API + "/gists/" + gistId, { headers: { "Authorization": "Bearer " + TOKEN } })
        .then(function(r) { return r.json(); })
        .then(function(gist) {
          var file = gist.files[FILE_NAME];
          allEntries = [];
          if (file) { try { allEntries = JSON.parse(file.content || "[]"); } catch(e) {} }
          renderEntries();
        })
        .catch(function() { $("entries-list").innerHTML = '<div class="empty-state" style="color:var(--danger)">加载失败</div>'; });
    }

    // ===== 渲染当前笔记本的笔记 =====
    function renderEntries() {
      var list = $("entries-list");
      if (!currentNotebook) {
        list.innerHTML = '<div class="empty-state"><p>请先选择笔记本</p></div>';
        $("list-count").textContent = "";
        return;
      }
      var filtered = allEntries.filter(function(e) { return e.notebook === currentNotebook; });
      filtered.sort(function(a, b) { return new Date(b.date || b.createdAt) - new Date(a.date || a.createdAt); });
      $("list-count").textContent = filtered.length + " 篇";

      if (!filtered.length) {
        list.innerHTML = '<div class="empty-state"><div class="icon">📝</div><p>该笔记本还没有远程笔记</p></div>';
        return;
      }

      list.innerHTML = "";
      filtered.forEach(function(e) {
        var d = document.createElement("div"); d.className = "entry-row";
        var date = e.date || (e.createdAt ? new Date(e.createdAt).toISOString().split("T")[0] : "");
        var preview = (e.content || "").replace(/[#*`>\-\[\]!]/g, "").replace(/\n/g, " ").slice(0, 80);
        d.innerHTML =
          '<div class="entry-info">' +
          '<div class="entry-title">' + esc(e.title || "无标题") + '</div>' +
          '<div class="entry-meta"><span>' + date + '</span></div>' +
          (preview ? '<div class="entry-preview">' + esc(preview) + '</div>' : "") +
          '</div>' +
          '<div class="entry-actions">' +
          '<button class="btn btn-sm" onclick="editEntry(\'' + e.id + '\')">编辑</button>' +
          '<button class="btn btn-danger-sm" onclick="deleteEntry(\'' + e.id + '\')">删除</button>' +
          '</div>';
        list.appendChild(d);
      });
    }

    // ===== 模板 =====
    // 从配置生成模板按钮
    (function() {
      var container = document.getElementById("template-buttons");
      if (!container || !TEMPLATES.length) return;
      TEMPLATES.forEach(function(tpl) {
        var btn = document.createElement("button");
        btn.className = "btn btn-sm";
        btn.textContent = tpl.icon + " " + tpl.name;
        btn.onclick = function() { applyTemplate(tpl); };
        container.appendChild(btn);
      });
    })();

    function applyTemplate(tpl) {
      if ($("content-input").value.trim() && !confirm("当前内容将被覆盖，确定切换模板？")) return;
      var today = new Date().toISOString().split("T")[0];
      $("entry-title").value = (tpl.title || "").replace(/\{name\}/g, today);
      $("content-input").value = tpl.content || "";
      updatePreview();
    }

    // ===== 编辑器工具栏 =====
    function insertMd(before, after) {
      var ta = $("content-input");
      var start = ta.selectionStart, end = ta.selectionEnd;
      var text = ta.value, selected = text.substring(start, end) || "文本";
      ta.value = text.substring(0, start) + before + selected + after + text.substring(end);
      ta.focus(); ta.selectionStart = start + before.length; ta.selectionEnd = start + before.length + selected.length;
      updatePreview();
    }

    var previewTimer = null;
    function updatePreview() {
      clearTimeout(previewTimer);
      previewTimer = setTimeout(function() {
        var md = $("content-input").value;
        $("preview-pane").innerHTML = md ? renderMarkdown(md) : '<div class="empty-state" style="padding:2rem;"><p>开始编辑后预览内容</p></div>';
      }, 200);
    }

    function renderMarkdown(md) {
      if (!md) return "";
      var html = md;
      html = html.replace(/```(\w*)\n([\s\S]*?)```/g, function(m, l, c) { return '<pre><code>' + esc(c) + '</code></pre>'; });
      html = html.replace(/`([^`]+)`/g, '<code>$1</code>');
      html = html.replace(/^### (.+)$/gm, '<h3>$1</h3>');
      html = html.replace(/^## (.+)$/gm, '<h2>$1</h2>');
      html = html.replace(/^# (.+)$/gm, '<h1>$1</h1>');
      html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
      html = html.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1">');
      html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank">$1</a>');
      html = html.replace(/^> (.+)$/gm, '<blockquote>$1</blockquote>');
      html = html.replace(/^- (.+)$/gm, '<li>$1</li>');
      html = html.replace(/(<li>.*<\/li>\n?)+/g, '<ul>$&</ul>');
      html = html.replace(/^---$/gm, '<hr>');
      html = html.replace(/\n\n/g, '</p><p>');
      html = html.replace(/\n/g, '<br>');
      html = '<p>' + html + '</p>';
      html = html.replace(/<p>\s*<\/p>/g, '');
      html = html.replace(/<p>\s*(<h[1-6]>)/g, '$1');
      html = html.replace(/(<\/h[1-6]>)\s*<\/p>/g, '$1');
      html = html.replace(/<p>\s*(<pre>)/g, '$1');
      html = html.replace(/(<\/pre>)\s*<\/p>/g, '$1');
      html = html.replace(/<p>\s*(<ul>)/g, '$1');
      html = html.replace(/(<\/ul>)\s*<\/p>/g, '$1');
      html = html.replace(/<p>\s*(<blockquote>)/g, '$1');
      html = html.replace(/(<\/blockquote>)\s*<\/p>/g, '$1');
      html = html.replace(/<p>\s*(<hr>)/g, '$1');
      html = html.replace(/(<hr>)\s*<\/p>/g, '$1');
      return html;
    }

    // ===== 编辑 =====
    function editEntry(id) {
      var entry = allEntries.find(function(e) { return e.id === id; });
      if (!entry) { toast("未找到", "err"); return; }
      editingEntryId = id;
      $("entry-title").value = entry.title || "";
      $("entry-date").value = entry.date || "";
      $("content-input").value = entry.content || "";
      $("submit-btn").textContent = "保存修改";
      $("edit-bar").classList.remove("hidden");
      updatePreview();
      window.scrollTo({ top: 0, behavior: "smooth" });
      toast("正在编辑: " + (entry.title || "无标题"), "ok");
    }

    function cancelEdit() {
      editingEntryId = null;
      $("entry-title").value = "";
      $("entry-date").value = new Date().toISOString().split("T")[0];
      $("content-input").value = "";
      $("submit-btn").textContent = "保存笔记";
      $("edit-bar").classList.add("hidden");
      updatePreview();
    }

    // ===== 提交 =====
    function submitEntry() {
      if (!currentNotebook) { toast("请先选择笔记本", "err"); return; }
      var content = $("content-input").value.trim();
      if (!content) { toast("请输入内容", "err"); return; }

      var title = $("entry-title").value.trim();
      var date = $("entry-date").value || new Date().toISOString().split("T")[0];
      var btn = $("submit-btn");
      var isEdit = !!editingEntryId;
      btn.disabled = true; btn.textContent = "保存中...";

      var gistId = NOTEBOOK_GISTS[currentNotebook];

      function doSave(gid) {
        var fetchGist = gid
          ? fetch(API + "/gists/" + gid, { headers: { "Authorization": "Bearer " + TOKEN } }).then(function(r) { return r.json(); })
          : Promise.resolve({ files: {} });

        fetchGist.then(function(gist) {
          var file = gist.files[FILE_NAME];
          var entries = [];
          if (file) { try { entries = JSON.parse(file.content || "[]"); } catch(e) {} }

          if (isEdit) {
            var idx = entries.findIndex(function(e) { return e.id === editingEntryId; });
            if (idx !== -1) {
              entries[idx].title = title;
              entries[idx].date = date;
              entries[idx].content = content;
              entries[idx].updatedAt = new Date().toISOString();
            }
          } else {
            entries.push({
              id: "nb-" + Date.now(),
              notebook: currentNotebook,
              title: title, date: date, content: content,
              createdAt: new Date().toISOString(),
              updatedAt: new Date().toISOString()
            });
          }

          var method = gid ? "PATCH" : "POST";
          var body = gid
            ? JSON.stringify({ files: { [FILE_NAME]: { content: JSON.stringify(entries, null, 2) } } })
            : JSON.stringify({ description: "firefly-notebook:" + currentNotebook, public: false, files: { [FILE_NAME]: { content: JSON.stringify(entries, null, 2) } } });

          return fetch(gid ? API + "/gists/" + gid : API + "/gists", {
            method: method,
            headers: { "Authorization": "Bearer " + TOKEN, "Content-Type": "application/json" },
            body: body
          }).then(function(r) {
            if (!r.ok) throw new Error("保存失败");
            return r.json();
          }).then(function(result) {
            if (!gid) {
              // 自动创建了新 Gist，提示用户填回配置
              NOTEBOOK_GISTS[currentNotebook] = result.id;
              toast("已保存 ✓ 新 Gist ID: " + result.id + "，请填回配置文件", "ok");
              // 更新标签状态
              tabs.forEach(function(t) {
                if (t.getAttribute("data-notebook") === currentNotebook) {
                  t.textContent = "✅ " + currentNotebook;
                }
              });
            } else {
              toast(isEdit ? "已保存 ✓" : "保存成功 ✓", "ok");
            }
            allEntries = entries;
            cancelEdit();
            renderEntries();
          });
        }).catch(function(e) {
          toast("保存失败: " + e.message, "err");
        }).finally(function() {
          btn.disabled = false; btn.textContent = isEdit ? "保存修改" : "保存笔记";
        });
      }

      doSave(gistId);
    }

    // ===== 删除 =====
    function deleteEntry(id) {
      if (!confirm("确定删除该笔记？")) return;
      var gistId = NOTEBOOK_GISTS[currentNotebook];
      if (!gistId) return;

      fetch(API + "/gists/" + gistId, { headers: { "Authorization": "Bearer " + TOKEN } })
        .then(function(r) { return r.json(); })
        .then(function(gist) {
          var file = gist.files[FILE_NAME];
          var entries = [];
          if (file) { try { entries = JSON.parse(file.content || "[]"); } catch(e) {} }
          entries = entries.filter(function(e) { return e.id !== id; });

          return fetch(API + "/gists/" + gistId, {
            method: "PATCH",
            headers: { "Authorization": "Bearer " + TOKEN, "Content-Type": "application/json" },
            body: JSON.stringify({ files: { [FILE_NAME]: { content: JSON.stringify(entries, null, 2) } } })
          });
        })
        .then(function(r) {
          if (!r.ok) throw new Error("删除失败");
          allEntries = allEntries.filter(function(e) { return e.id !== id; });
          toast("已删除", "ok");
          renderEntries();
        })
        .catch(function(e) { toast("删除失败: " + e.message, "err"); });
    }

    // ===== 初始化 =====
    (function() {
      if (sessionStorage.getItem("admin_auth") !== "1") { window.location.href = "/admin/"; return; }
      $("entry-date").value = new Date().toISOString().split("T")[0];
      $("content-input").addEventListener("input", updatePreview);
      if (TOKEN) { $("token-input").value = TOKEN; }
      validateAndLoad();
    })();
  </script>
</body>
</html>
